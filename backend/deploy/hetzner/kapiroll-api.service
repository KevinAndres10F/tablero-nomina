[Unit]
Description=KAPIROLL FastAPI backend
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/tablero-nomina/backend
EnvironmentFile=/opt/tablero-nomina/backend/.env
ExecStart=/opt/tablero-nomina/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
